# Google Cloud Configuration
# CI puede ejecutarse sin credenciales GCP: si estas variables no existen,
# el backend usa fallback in-memory y el frontend solo necesita compilar.
GOOGLE_APPLICATION_CREDENTIALS=path/to/your/credentials.json
GOOGLE_SHEET_ID=your_google_sheet_id_here
GOOGLE_SHEET_OWNER_EMAIL=owner@email.com

# Backend Configuration
PORT=3001
CORS_ORIGIN=http://localhost:3000
JWT_SECRET=PUT_A_LONG_RANDOM_STRING_HERE
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
AUTH_BOOTSTRAP_ADMIN_USERNAME=admin
AUTH_BOOTSTRAP_ADMIN_PASSWORD=CHANGE_ME_IN_PRODUCTION
AUTH_BOOTSTRAP_ADMIN_NAME=Administrador
AUTH_BOOTSTRAP_AGENT_USERNAME=agent
AUTH_BOOTSTRAP_AGENT_PASSWORD=CHANGE_ME_IN_PRODUCTION
AUTH_BOOTSTRAP_AGENT_NAME=Agente

# Rate limiting
RATE_LIMIT_GLOBAL=10/min
RATE_LIMIT_LOGIN=5/15min
LOG_DIR=logs

# Frontend Configuration
# Leave empty to use the built-in /api proxy through Next.js.
# CI deja esta variable vacia para validar lint y build sin depender de un backend externo.
NEXT_PUBLIC_API_URL=
